{
  "name": "@specd/specd-ds",
  "version": "0.1.0",
  "description": "Specd DS — framework-agnostic Web Component library with auto-generated React wrappers",
  "type": "module",
  "main": "./dist/web-components/index.cjs.js",
  "module": "./dist/web-components/index.esm.js",
  "exports": {
    ".": {
      "import": "./dist/web-components/index.esm.js",
      "require": "./dist/web-components/index.cjs.js"
    },
    "./react": {
      "import": "./dist/react/index.esm.js"
    },
    "./tokens.css": "./dist/tokens.css",
    "./components.css": "./dist/components.css"
  },
  "types": "./dist/web-components/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "npm run build:wc && npm run build:react && npm run build:css",
    "build:wc": "vite build",
    "build:react": "vite build --config vite.react.config.ts",
    "build:css": "node scripts/build-css.mjs",
    "build:analyze": "cem analyze --globs 'src/**/*.ts' --outdir dist",
    "build:storybook": "storybook build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "lit": "^3.0.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.10.0",
    "@lit/react": "^1.0.0",
    "@storybook/web-components-vite": "^10.4.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "happy-dom": "^20.9.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.0.0",
    "vitest": "^3.0.0",
    "storybook": "^10.4.0",
    "@chromatic-com/storybook": "^5.2.1",
    "@storybook/addon-vitest": "^10.4.0",
    "@storybook/addon-a11y": "^10.4.0",
    "@storybook/addon-docs": "^10.4.0",
    "playwright": "^1.60.0",
    "@vitest/browser": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0"
  }
}
